# Database
DB_URL=jdbc:mysql://localhost:3306/demodb2?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# JWT
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_32_chars

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-account@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
